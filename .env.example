# Copy to .env and fill in. All values are optional for tests (sane defaults).

# ── Anthropic / Claude (generation) ─────────────────────────────────────────
ANTHROPIC_API_KEY=
# MODEL_DEFAULT=claude-sonnet-4-6
# MODEL_HIGHSTAKES=claude-opus-4-8

# ── Ingestion data sources (signals) ────────────────────────────────────────
# FOREX_FACTORY_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
NEWS_API_KEY=
MARKET_DATA_API_KEY=

# ── Email delivery (Brevo / Sendinblue) ─────────────────────────────────────
BREVO_API_KEY=
# SENDER_FROM_EMAIL=flashes@example.com
# SENDER_FROM_NAME=Desk FX

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///news_flashes.db

# ── Scheduling ───────────────────────────────────────────────────────────────
# POLL_INTERVAL_MINUTES=15

# ── FX basket (comma-separated) ─────────────────────────────────────────────
# BASKET_CURRENCIES=USD,EUR,JPY,TND
