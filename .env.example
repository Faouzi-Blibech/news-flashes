# ── Anthropic / Claude ──────────────────────────────────────────────────────
# Your Anthropic API key (required for draft generation)
ANTHROPIC_API_KEY=

# Override the default model used for drafting (optional)
# MODEL_DEFAULT=claude-sonnet-4-6

# Override the high-stakes model used for final review (optional)
# MODEL_HIGHSTAKES=claude-opus-4-8

# ── FX basket ────────────────────────────────────────────────────────────────
# Comma-separated list of currencies to track (optional, has sensible default)
# BASKET_CURRENCIES=["USD","EUR","JPY","TND"]

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (optional, defaults to news_flashes.db)
# DB_PATH=news_flashes.db

# ── Email delivery (Brevo / Sendinblue) ─────────────────────────────────────
# Brevo transactional email API key (required for sending)
BREVO_API_KEY=

# Sender address shown to clients (optional)
# SENDER_FROM_EMAIL=flashes@example.com

# Sender display name shown to clients (optional)
# SENDER_FROM_NAME=Desk FX
