# Copy this file to .env and fill in real values. Never commit .env.

# Claude / Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Economic calendar (Forex Factory public JSON — default works without a key)
FOREX_FACTORY_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# News headlines (Marketaux or NewsAPI.org free tier)
NEWS_API_KEY=your-news-api-key-here

# FX market data (Twelve Data / Alpha Vantage / exchangerate.host)
MARKET_DATA_API_KEY=your-market-data-api-key-here

# Email delivery (Brevo — 300 emails/day free)
BREVO_API_KEY=your-brevo-api-key-here

# Storage
DATABASE_URL=sqlite:///news_flashes.db

# Scheduler
POLL_INTERVAL_MINUTES=15

# Currency basket to monitor (comma-separated, no spaces)
BASKET_CURRENCIES=USD,EUR,JPY,TND
